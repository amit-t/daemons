#!/usr/bin/env zsh
# dag — Devin Enterprise ACU governor.
# Thin launcher: resolves the Devin API keys, assembles a playbook prompt,
# and hands the job to a Claude agent session (DAG_LAUNCHER, default clscb).
# Primary key: Devin API v3 service-user key (cog_..., api.devin.ai) — required.
# Secondary: Windsurf service key (server.codeium.com) — optional, enables
# per-model/IDE breakdown and roster activity analytics.
set -u
script_path=${0:A}
daemon_dir=${script_path:h:h}

source "${daemon_dir}/lib/key-resolve.zsh"

dag_load_env() {
  local env_file="${daemon_dir}/environment.env" line key value
  [[ -f "$env_file" ]] || return 0
  while IFS= read -r line; do
    [[ "$line" == \#* || "$line" != *=* ]] && continue
    key=${line%%=*}
    value=${line#*=}
    if [[ -z "${(P)key:-}" ]]; then
      typeset -gx "$key"="$value"
    fi
  done < "$env_file"
}

dag_usage() {
  cat <<'EOF'
dag — Devin Enterprise ACU governor

Usage:
  dag set-limits              Prorate remaining ACUs and PATCH per-user Local Agent limits
  dag set limit global <acus> [org_id|org_name]
                              Set org-level Local Agent limit(s), then live-GET verify each
  dag set-limit global <acus> [org_id|org_name]
                              Alias for: dag set limit global
  dag boost <email> [acus]    Reallocate ACUs to a heavy user from the lowest consumers
                              (recommends amount + donors; omit [acus] to use the recommendation)
  dag user <email>            Deep-dive one user's consumption and model usage (read-only)
  dag status                  Consumption, remaining ACUs, month-end projection
  dag models [file|names...]  Per-model burn report + Admin Portal allowlist walkthrough
  dag all commands [task...]  Open a generic Devin API/DAG lab seeded with docs + all playbooks
  dag all-commands [task...]  Alias for: dag all commands
  dag doctor                  Probe both API keys and report which capabilities they hold
  dag dashboard [--no-open] [--json-only] [--out <dir>]
                              Local ACU burn-rate + forecast dashboard (read-only, no agent)
  dag help                    Show this help

Config (environment.env; shell env vars override):
  DAG_MONTHLY_ACU_POOL       monthly ACU pool (default 24000)
  DAG_LAUNCHER               agent launcher command (default clscb)
  DAG_COG_KEYCHAIN_SERVICE   keychain item, Devin v3 cog_ key (default devin-cog-key)
  DAG_KEYCHAIN_SERVICE       keychain item, Windsurf service key (default devin-service-key)
  DAG_STATE_DIR              ledger directory (default ~/.local/state/devin-acu-governor)

Keys, one-time setup:
  Required — Devin API v3 service-user key (app.devin.ai > Settings > Service users,
  enterprise-scoped, permissions ViewAccountConsumption + ManageBilling + ViewOrgSessions + ViewAccountMetrics):
    security add-generic-password -s devin-cog-key -a "$USER" -w 'cog_...'
    Fallback: export DEVIN_COG_KEY=cog_...
  Optional — Windsurf service key (windsurf.com/team/settings; Analytics Read +
  Teams Read-only) for per-model/IDE breakdown and roster activity:
    security add-generic-password -s devin-service-key -a "$USER" -w '<key>'
    Fallback: export DEVIN_SERVICE_KEY=<key>
EOF
}

dag_build_prompt() {  # $1 = command, rest = extra run-context lines
  local cmd="$1"; shift
  cat "${daemon_dir}/playbooks/_common.md" "${daemon_dir}/playbooks/${cmd}.md"
  if [[ "$cmd" == "all-commands" ]]; then
    print -r -- ""
    print -r -- "## Existing DAG command playbooks"
    print -r -- ""
    local playbook
    for playbook in set-limits boost user status models; do
      print -r -- ""
      print -r -- "### ${playbook}"
      cat "${daemon_dir}/playbooks/${playbook}.md"
    done
  fi
  print -r -- ""
  print -r -- "## Run context"
  print -r -- "- command: ${cmd}"
  print -r -- "- today: $(date +%F)"
  print -r -- "- DAG_MONTHLY_ACU_POOL: ${DAG_MONTHLY_ACU_POOL}"
  print -r -- "- compute_caps_jq: ${daemon_dir}/lib/compute-caps.jq"
  print -r -- "- boost_check_jq: ${daemon_dir}/lib/boost-check.jq"
  print -r -- "- boost_plan_jq: ${daemon_dir}/lib/boost-plan.jq"
  print -r -- "- ledger: ${DAG_STATE_DIR}/allocations.json"
  if [[ -n "${_dag_have_cog_key:-}" ]]; then
    print -r -- "- Devin v3 key: exported as DEVIN_COG_KEY in this shell. Never print it."
  else
    print -r -- "- Devin v3 key: ABSENT — docs/design mode only; ask the user to configure DEVIN_COG_KEY before live Devin API calls."
  fi
  if [[ -n "${_dag_have_windsurf_key}" ]]; then
    print -r -- "- Windsurf key: exported as DEVIN_SERVICE_KEY in this shell. Never print it."
  else
    print -r -- "- Windsurf key: ABSENT — skip server.codeium.com calls; per-model/IDE breakdown and roster activity unavailable."
  fi
  local line
  for line in "$@"; do print -r -- "- ${line}"; done
}

main() {
  dag_load_env
  : ${DAG_MONTHLY_ACU_POOL:=24000}
  : ${DAG_LAUNCHER:=clscb}
  : ${DAG_STATE_DIR:=${HOME}/.local/state/devin-acu-governor}

  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then
    dag_usage >&2
    exit 2
  fi
  shift

  local -a context_lines
  context_lines=()
  case "$cmd" in
    help|-h|--help)
      dag_usage
      exit 0
      ;;
    doctor)
      source "${daemon_dir}/lib/doctor.zsh"
      dag_doctor
      exit $?
      ;;
    dashboard)
      source "${daemon_dir}/lib/dashboard.zsh"
      dag_dashboard "$@"
      exit $?
      ;;
    set)
      if [[ "${1:-}" == "limit" && "${2:-}" == "global" ]]; then
        shift 2
        source "${daemon_dir}/lib/local-agent-limits.zsh"
        dag_set_limit_global "$@"
        exit $?
      fi
      print -ru2 -- "dag: unknown set command (expected: dag set limit global <acus> [org_id|org_name]; omit selector to update all orgs)"
      dag_usage >&2
      exit 2
      ;;
    set-limit)
      if [[ "${1:-}" == "global" ]]; then
        shift
        source "${daemon_dir}/lib/local-agent-limits.zsh"
        dag_set_limit_global "$@"
        exit $?
      fi
      print -ru2 -- "dag: unknown set-limit command (expected: dag set-limit global <acus> [org_id|org_name]; omit selector to update all orgs)"
      dag_usage >&2
      exit 2
      ;;
    set-limit-global)
      source "${daemon_dir}/lib/local-agent-limits.zsh"
      dag_set_limit_global "$@"
      exit $?
      ;;
    set-limits|status) ;;
    all)
      if [[ "${1:-}" != "commands" ]]; then
        print -ru2 -- "dag: unknown all command (expected: dag all commands [task...])"
        dag_usage >&2
        exit 2
      fi
      shift
      cmd="all-commands"
      if (( $# > 0 )); then
        context_lines=("requested shell command: dag all commands" "generic task: $*" "spin-up trigger phrase: spin it up")
      else
        context_lines=("requested shell command: dag all commands" "generic task: not provided — start by asking the user what Devin/API task they want to explore or automate" "spin-up trigger phrase: spin it up")
      fi
      ;;
    all-commands)
      if (( $# > 0 )); then
        context_lines=("requested shell command: dag all-commands" "generic task: $*" "spin-up trigger phrase: spin it up")
      else
        context_lines=("requested shell command: dag all-commands" "generic task: not provided — start by asking the user what Devin/API task they want to explore or automate" "spin-up trigger phrase: spin it up")
      fi
      ;;
    boost)
      local email="${1:-}" amount="${2:-}"
      if [[ "$email" != *@*.* ]]; then
        print -ru2 -- "dag boost: first argument must be a user email (got: ${email:-<missing>})"
        exit 2
      fi
      if [[ -n "$amount" && "$amount" != <1-> ]]; then
        print -ru2 -- "dag boost: optional second argument must be a positive integer ACU amount (got: ${amount})"
        exit 2
      fi
      context_lines=("boost target: ${email}")
      if [[ -n "$amount" ]]; then
        context_lines+=("explicit increment: ${amount}")
      else
        context_lines+=("explicit increment: none — recommend from the user's run-rate projection")
      fi
      ;;
    user)
      local user_email="${1:-}"
      if [[ "$user_email" != *@*.* ]]; then
        print -ru2 -- "dag user: argument must be a user email (got: ${user_email:-<missing>})"
        exit 2
      fi
      context_lines=("user: ${user_email}")
      ;;
    models)
      if [[ -n "${1:-}" && -f "${1:-}" ]]; then
        context_lines=("desired model allowlist (from file $1):" "$(cat "$1")")
      elif (( $# > 0 )); then
        context_lines=("desired model allowlist: $*")
      else
        context_lines=("desired model allowlist: not provided — report current usage only")
      fi
      ;;
    *)
      print -ru2 -- "dag: unknown command '${cmd}'"
      dag_usage >&2
      exit 2
      ;;
  esac

  local cog_key windsurf_key
  typeset -g _dag_have_cog_key=""
  if ! cog_key=$(dag_resolve_cog_key); then
    if [[ "$cmd" == "all-commands" ]]; then
      print -ru2 -- "dag: note — no Devin API v3 service-user key; all-commands will run in docs/design mode only."
    else
      print -ru2 -- "dag: no Devin API v3 service-user key (cog_...) found."
      print -ru2 -- "  Create one at app.devin.ai > Settings > Service users (enterprise-scoped),"
      print -ru2 -- "  permissions: ViewAccountConsumption, ManageBilling, ViewOrgSessions, ViewAccountMetrics."
      print -ru2 -- "  Keychain: security add-generic-password -s ${DAG_COG_KEYCHAIN_SERVICE:-devin-cog-key} -a \"\$USER\" -w 'cog_...'"
      print -ru2 -- "  Or: export DEVIN_COG_KEY=cog_..."
      exit 1
    fi
  else
    _dag_have_cog_key=1
  fi
  typeset -g _dag_have_windsurf_key=""
  if windsurf_key=$(dag_resolve_service_key); then
    _dag_have_windsurf_key=1
  else
    print -ru2 -- "dag: note — no Windsurf service key; per-model/IDE breakdown and roster activity degraded."
  fi

  mkdir -p "${DAG_STATE_DIR}"
  local prompt
  prompt=$(dag_build_prompt "$cmd" "${context_lines[@]}")

  if [[ -n "${DAG_PRINT_PROMPT:-}" ]]; then
    print -r -- "$prompt"
    exit 0
  fi

  [[ -n "$_dag_have_cog_key" ]] && export DEVIN_COG_KEY="$cog_key"
  [[ -n "$_dag_have_windsurf_key" ]] && export DEVIN_SERVICE_KEY="$windsurf_key"
  exec zsh -ic "${DAG_LAUNCHER} $(printf '%q' "$prompt")"
}

main "$@"
