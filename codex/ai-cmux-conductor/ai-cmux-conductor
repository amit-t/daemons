#!/usr/bin/env bun
import { parseAiCmuxConductorArgs } from "./src/ai-cmux-conductor/args.ts";
import { loadAiCmuxConductorEnv } from "./src/ai-cmux-conductor/config.ts";
import { runCodexLauncher } from "./src/ai-cmux-conductor/codex-launch.ts";
import { runAiCmuxConductorDaemon } from "./src/ai-cmux-conductor/watcher-daemon.ts";
import { buildOrchestratorPrompt, conductorHelpText, prepareConductor } from "./src/ai-cmux-conductor/conductor.ts";
import { buildResetStatusText, resetAiCmuxWorkspace } from "./src/ai-cmux-conductor/reset.ts";
import {
  FileClaudeAutoResumeStore,
  claudeAutoResumeStatePath,
  ensureClaudeAutoResumeDaemon,
  loadClaudeAutoResumeStatus,
  registerClaudeSurfaceFromConductorContext,
  stopClaudeAutoResumeDaemon,
} from "./src/ai-cmux-conductor/claude-auto-resume.ts";
import {
  FileDevinPollStore,
  devinPollStatePath,
  loadDevinPollStatus,
  loadUnreadDevinPollEvents,
  registerDevinPollFromConductorContext,
} from "./src/ai-cmux-conductor/devin-poll.ts";

const args = parseAiCmuxConductorArgs(process.argv);

if (args.help) {
  console.log(conductorHelpText());
  process.exit(0);
}

const conductorEnv = loadAiCmuxConductorEnv(process.env);
const autoResumeStore = new FileClaudeAutoResumeStore(claudeAutoResumeStatePath(conductorEnv));
const devinPollStore = new FileDevinPollStore(devinPollStatePath(conductorEnv));

if (args.status) {
  console.log(`${await loadClaudeAutoResumeStatus(autoResumeStore)}\n\n${await loadDevinPollStatus(devinPollStore)}`);
  process.exit(0);
}

if (args.events) {
  process.stdout.write(await loadUnreadDevinPollEvents(devinPollStore, { markRead: args.unread, now: new Date() }));
  process.exit(0);
}

if (args.stopDaemon) {
  const stopped = await stopClaudeAutoResumeDaemon(conductorEnv);
  console.log(stopped.stopped ? `Stopped AICC watcher daemon pid ${stopped.pid}.` : `AICC watcher daemon not stopped: ${stopped.reason || "not running"}.`);
  process.exit(stopped.stopped || stopped.reason === "not running" ? 0 : 1);
}

if (args.reset) {
  const result = await resetAiCmuxWorkspace({
    env: conductorEnv,
    beforeClose: async () => {
      await stopClaudeAutoResumeDaemon(conductorEnv);
    },
  });
  console.log(buildResetStatusText(result));
  process.exit(result.mode === "reset" ? 0 : result.mode === "blocked" ? 2 : 1);
}

if (args.daemon) {
  await runAiCmuxConductorDaemon({ claudeStore: autoResumeStore, devinStore: devinPollStore, env: conductorEnv });
}

const prepared = await prepareConductor({ cwd: process.cwd(), env: conductorEnv });

if (prepared.mode === "handoff") {
  console.log(prepared.message);
  process.exit(0);
}

if (prepared.mode === "error") {
  console.error(prepared.message);
  if (prepared.stderr) console.error(prepared.stderr.trim());
  process.exit(1);
}

try {
  await registerClaudeSurfaceFromConductorContext(prepared.context, conductorEnv.CMUX_WINDOW_ID, autoResumeStore);
  await registerDevinPollFromConductorContext(prepared.context, conductorEnv.CMUX_WINDOW_ID, devinPollStore);
  await ensureClaudeAutoResumeDaemon(conductorEnv);
} catch (error) {
  const message = error instanceof Error ? error.message : String(error);
  console.warn(`AICC watcher daemon warning: ${message}`);
}

const prompt = `${buildOrchestratorPrompt(prepared.context)}${args.prompt ? `\n\n## Initial user request\n${args.prompt}` : ""}`;
await runCodexLauncher(prompt, process.cwd());
