# ai-cmux-conductor feature flags
#
# Claude side panel is enabled by default.
# Set to false to leave existing Claude panes untouched and omit Claude routing.
AICC_CREATE_CLAUDE_PANEL=true

# Codex side panel is enabled by default.
# This is the extra Codex panel under Claude; the base orchestrator still runs in cMUX.
AICC_CREATE_CODEX_PANEL=true

# Set to true to create/manage the Devin panel.
AICC_CREATE_DEVIN_PANEL=false

# Claude usage-limit auto-resume watcher auto-starts by default.
# Set to false to register surfaces without starting the detached watcher.
# AICC_CLAUDE_AUTO_RESUME_DAEMON=true

# Agent event polling runs in the same watcher by default.
# Set to false to keep panes but stop enabled Claude/Codex/Devin event-inbox notifications.
# AICC_DEVIN_POLL_DAEMON=true
