# do-here-now-migrator configuration. Shell environment variables override these.

# Agent launchers. These are zsh functions/aliases in the interactive shell, so
# the daemon starts them through `zsh -ic`.
DHM_LAUNCHER=co
DHM_LAUNCHER_CLAUDE=co
DHM_LAUNCHER_CLAUDE_FABLE=cf
DHM_LAUNCHER_CODEX=cxscb
DHM_LAUNCHER_DEVIN=dey

# here.now API base. Override only to point at a staging deployment.
DHM_HERENOW_API=https://here.now

# TTL applied to DNS records this daemon creates. Low, so a mistake can be
# corrected quickly during a cutover.
DHM_DNS_TTL=600

# Per-request HTTP timeout, in seconds.
DHM_HTTP_TIMEOUT=30

# Node version the generated GitHub Actions workflow pins.
DHM_CI_NODE_VERSION=22
